<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <!--
        Added the constraints for entity Task.
    -->
    <changeSet id="20260630174252-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="sprint_id"
                                 baseTableName="task"
                                 constraintName="fk_task__sprint_id"
                                 referencedColumnNames="id"
                                 referencedTableName="sprint"
                                 />

        <addForeignKeyConstraint baseColumnNames="milestone_id"
                                 baseTableName="task"
                                 constraintName="fk_task__milestone_id"
                                 referencedColumnNames="id"
                                 referencedTableName="milestone"
                                 />

        <addForeignKeyConstraint baseColumnNames="assigned_to_id"
                                 baseTableName="task"
                                 constraintName="fk_task__assigned_to_id"
                                 referencedColumnNames="id"
                                 referencedTableName="employee"
                                 />

        <addForeignKeyConstraint baseColumnNames="created_by_id"
                                 baseTableName="task"
                                 constraintName="fk_task__created_by_id"
                                 referencedColumnNames="id"
                                 referencedTableName="employee"
                                 />
    </changeSet>
</databaseChangeLog>
